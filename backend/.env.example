# ============================================================================
# CONFIGURACIÓN DEL ENTORNO
# ============================================================================
# Copia este archivo a .env y configura los valores según tu entorno

# ============================================================================
# GENERAL
# ============================================================================

# Entorno: development | staging | production
NODE_ENV=development

# Puerto del servidor
PORT=3000

# ============================================================================
# BASE DE DATOS (PostgreSQL)
# ============================================================================

DB_HOST=localhost
DB_PORT=5432
DB_NAME=ggs_db
DB_USER=postgres
DB_PASSWORD=postgres

# Configuración del pool de conexiones
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000

# ============================================================================
# JWT (JSON Web Tokens)
# ============================================================================

# CRÍTICO: Genera un secreto seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Debe tener al menos 32 caracteres
JWT_SECRET=2b725cb8639c1fe747e3a9b2c1fba993a743bf1ee7abdd18f5aba61b9709c39b

# Expiración del access token (15m recomendado para producción)
JWT_EXPIRES_IN=15m

# ============================================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================================

# Origen permitido para peticiones CORS
# Desarrollo: http://localhost:5173
# Producción: https://tu-dominio.com (separar múltiples con comas)
CORS_ORIGIN=http://localhost:5173

# ============================================================================
# RATE LIMITING
# ============================================================================

# Ventana de tiempo para rate limiting (en milisegundos)
# 15 minutos = 900000 ms
RATE_LIMIT_WINDOW_MS=900000

# Máximo de peticiones por ventana
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# ARCHIVOS Y UPLOADS
# ============================================================================

# Directorio para subir archivos
UPLOAD_DIR=./uploads

# Tamaño máximo de archivo (en bytes)
# 10MB = 10485760 bytes
MAX_FILE_SIZE=10485760

# ============================================================================
# SEGURIDAD
# ============================================================================

# Máximo de intentos de login fallidos antes de bloquear
MAX_LOGIN_ATTEMPTS=5

# Tiempo de bloqueo por intentos fallidos (en minutos)
LOCK_TIME_MINUTES=15

# ============================================================================
# FIRMA ELECTRÓNICA (Futuro)
# ============================================================================

# Habilitar firma electrónica
SIGNATURE_ENABLED=false

# Algoritmo de firma
SIGNATURE_ALGORITHM=RSA-SHA256

# ============================================================================
# LOGGING
# ============================================================================

# Nivel de logging: error | warn | info | debug
LOG_LEVEL=debug

# Directorio de logs
LOG_DIR=./logs

# ============================================================================
# HTTPS/SSL (SOLO PRODUCCIÓN)
# ============================================================================
# Descomentar y configurar en producción

# Habilitar HTTPS
# HTTPS_ENABLED=true

# Ruta al certificado SSL
# SSL_CERT_PATH=/path/to/certificate.crt

# Ruta a la clave privada SSL
# SSL_KEY_PATH=/path/to/private.key

# ============================================================================
# REDIS (OPCIONAL - Recomendado para producción)
# ============================================================================
# Para sesiones, cache y rate limiting distribuido

# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ============================================================================
# EMAIL (OPCIONAL - Para notificaciones)
# ============================================================================

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu_email@gmail.com
# SMTP_PASSWORD=tu_contraseña_app
# SMTP_FROM="SIGA <noreply@tu-dominio.com>"

# ============================================================================
# AUDITORÍA Y MONITOREO
# ============================================================================

# Habilitar auditoría detallada
AUDIT_ENABLED=true

# Retención de logs de auditoría (en días)
AUDIT_RETENTION_DAYS=365

# ============================================================================
# DESARROLLO (Solo para desarrollo)
# ============================================================================

# Mostrar logs SQL en consola
DEBUG_SQL=true

# Habilitar modo debug
DEBUG=false
