# ============================================================================
# ARCHIVO DE VARIABLES DE ENTORNO - SIGA
# CONFIGURACIÓN OPTIMIZADA PARA 200 USUARIOS CONCURRENTES
# ============================================================================
#
# INSTRUCCIONES:
# 1. Copiar este archivo como .env (sin .optimizado)
# 2. Modificar valores según tu entorno
# 3. NUNCA commitear .env al repositorio Git
# 4. Generar JWT_SECRET seguro: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# ============================================================================

# ============================================================================
# ENTORNO
# ============================================================================
NODE_ENV=production
PORT=3000

# ============================================================================
# BASE DE DATOS - CONFIGURACIÓN OPTIMIZADA PARA 200 USUARIOS
# ============================================================================

# Conexión PostgreSQL
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gestordocumental
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Pool de conexiones - OPTIMIZADO PARA 200 USUARIOS CONCURRENTES
# Cálculo: 200 usuarios x 0.25 conexiones promedio = 50 conexiones
DB_POOL_MAX=50
# Aumentado de 20 a 50 para soportar carga concurrente

# Tiempo antes de cerrar conexión inactiva (milisegundos)
DB_POOL_IDLE_TIMEOUT=60000
# Aumentado de 30s a 60s para reducir overhead de reconexión

# Timeout máximo esperando conexión disponible (milisegundos)
DB_POOL_CONNECTION_TIMEOUT=5000
# Aumentado de 2s a 5s para tolerar picos de carga

# Tiempo antes de cancelar query lento (milisegundos)
# Ayuda a liberar conexiones bloqueadas por queries problemáticas
DB_STATEMENT_TIMEOUT=30000
# 30 segundos máximo por query

# ============================================================================
# SEGURIDAD JWT
# ============================================================================

# Secret para firmar tokens JWT (OBLIGATORIO - mínimo 64 caracteres)
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_OF_AT_LEAST_64_CHARACTERS

# Duración del access token (tiempo antes de requerir refresh)
JWT_EXPIRES_IN=15m
# 15 minutos - balance entre seguridad y UX

# Duración del refresh token (días)
JWT_REFRESH_EXPIRES_IN=7d
# 7 días - sesiones de largo plazo

# ============================================================================
# RATE LIMITING - OPTIMIZADO PARA 200 USUARIOS
# ============================================================================

# Ventana de tiempo para contar requests (milisegundos)
RATE_LIMIT_WINDOW_MS=900000
# 15 minutos (15 * 60 * 1000)

# Máximo de requests por usuario en la ventana
RATE_LIMIT_MAX_REQUESTS=300
# 300 requests cada 15 min = 20 req/min promedio por usuario
# Capacidad total: 200 usuarios × 300 req = 60,000 req/15min = 66.6 req/s

# Rate limit específico para login (prevenir brute force)
RATE_LIMIT_LOGIN_MAX=5
# Solo 5 intentos de login cada 15 minutos

# Debug mode para rate limiting (mostrar stats en headers)
RATE_LIMIT_DEBUG=false
# Cambiar a true solo en desarrollo

# ============================================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================================

# Origen permitido para requests CORS
CORS_ORIGIN=http://localhost:5173
# En producción: https://siga.gob.mx

# Orígenes múltiples (separados por coma)
# CORS_ORIGIN=http://localhost:5173,https://siga.gob.mx,https://siga-dev.gob.mx

# ============================================================================
# ARCHIVOS Y UPLOADS
# ============================================================================

# Directorio para guardar archivos subidos
UPLOAD_DIR=./uploads
# Cambiar a ruta absoluta en producción: /var/www/siga/uploads

# Tamaño máximo de archivo (bytes)
MAX_FILE_SIZE=10485760
# 10 MB (10 * 1024 * 1024)

# Tipos de archivo permitidos (separados por coma)
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png,zip

# ============================================================================
# SEGURIDAD GENERAL
# ============================================================================

# Intentos máximos de login antes de bloquear cuenta
MAX_LOGIN_ATTEMPTS=5

# Tiempo de bloqueo después de exceder intentos (minutos)
LOCK_TIME_MINUTES=15

# Habilitar HTTPS (certificados SSL)
HTTPS_ENABLED=false
# Cambiar a true en producción

# Rutas a certificados SSL (solo si HTTPS_ENABLED=true)
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# ============================================================================
# LOGGING
# ============================================================================

# Nivel de logging: error, warn, info, debug
LOG_LEVEL=info
# Usar 'debug' solo en desarrollo

# Archivo de logs
LOG_FILE=./logs/app.log

# Log de requests autenticados (incluye IP, usuario, ruta)
LOG_AUTH_REQUESTS=false
# Cambiar a true para auditoría completa (aumenta tamaño de logs)

# ============================================================================
# FIRMA ELECTRÓNICA (FUTURO)
# ============================================================================

# Habilitar módulo de firma electrónica
SIGNATURE_ENABLED=false

# Algoritmo de firma
SIGNATURE_ALGORITHM=RSA-SHA256

# Ruta a keystore de certificados
SIGNATURE_KEYSTORE_PATH=/path/to/keystore.p12

# ============================================================================
# REDIS (OPCIONAL - RECOMENDADO EN PRODUCCIÓN)
# ============================================================================

# Habilitar Redis para caché y rate limiting distribuido
REDIS_ENABLED=false
# Cambiar a true al configurar Redis

# URL de conexión Redis
REDIS_URL=redis://localhost:6379
# En producción: redis://usuario:password@host:6379/0

# Base de datos Redis (0-15)
REDIS_DB=0

# Tiempo de reconexión (milisegundos)
REDIS_RETRY_DELAY=1000

# ============================================================================
# BULL QUEUE (OPCIONAL - PARA TAREAS ASÍNCRONAS)
# ============================================================================

# Habilitar colas de trabajo (requiere Redis)
BULL_ENABLED=false

# Ruta a Redis para Bull
BULL_REDIS_URL=redis://localhost:6379

# ============================================================================
# MONITOREO Y MÉTRICAS (OPCIONAL)
# ============================================================================

# Habilitar endpoint de métricas Prometheus
METRICS_ENABLED=false

# Puerto para métricas (separado del puerto principal)
METRICS_PORT=9090

# Habilitar health check avanzado (verifica BD, Redis, disco)
ADVANCED_HEALTH_CHECK=true

# ============================================================================
# CONFIGURACIÓN ESPECÍFICA DE PRODUCCIÓN
# ============================================================================

# En producción, además de este archivo, configurar:
#
# 1. PostgreSQL:
#    ALTER SYSTEM SET max_connections = 100;
#    ALTER SYSTEM SET shared_buffers = '256MB';
#    ALTER SYSTEM SET effective_cache_size = '1GB';
#
# 2. Firewall:
#    - Permitir solo IPs corporativas en puerto 3000
#    - Bloquear acceso directo a PostgreSQL (puerto 5432)
#
# 3. Proxy Reverso (nginx):
#    - Configurar HTTPS con Let's Encrypt
#    - Habilitar compresión gzip
#    - Limitar tamaño de request body
#
# 4. Systemd Service:
#    - Configurar reinicio automático
#    - Configurar límites de recursos (ulimit)
#
# 5. Backups:
#    - Backup diario de PostgreSQL con pg_dump
#    - Rotación de logs con logrotate
#    - Backup de uploads/ a almacenamiento externo
#
# 6. Monitoreo:
#    - Configurar Prometheus + Grafana
#    - Alertas para pool exhausted, queries lentos, errors >5%
#    - Log aggregation con ELK o Loki
#
# ============================================================================

# ============================================================================
# EJEMPLO DE USO EN DOCKER COMPOSE
# ============================================================================
#
